# Required
IMMICH_API_KEY=your-immich-api-key-here
IMMICH_API_URL=http://host.docker.internal:2283

# Ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3-vl:4b

# Processing
# CONCURRENCY=1
# MODE=continuous
# CHECK_INTERVAL=3600
# MAX_ASSETS=0

# Album names (created automatically in Immich)
# ALBUM_TRASH=To Delete
# ALBUM_REVIEW=To Review
